## Project-wide yamllint config.
## Phase 2: lenient. Per-component tightening can override at component level.
extends: relaxed
rules:
  line-length: disable
  document-start: disable
  truthy: disable
  comments: disable
  comments-indentation: disable
  empty-lines: disable
  indentation: disable
  trailing-spaces: disable
  new-line-at-end-of-file: disable
ignore: |
  baseline/
  third_party/
