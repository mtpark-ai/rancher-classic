#!/usr/bin/env bash
## Add a v1.7.0 version to each kept infra-template under
## components/catalog/. Each new version copies the previous version's
## compose files, repoints rancher/* images at the fork's GHCR images,
## and bumps minimum_rancher_version to v1.7.0.
##
## Idempotent: skips templates that already have a v1.7.0 version.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CATALOG="$REPO_ROOT/components/catalog/infra-templates"

## Map: template name -> upstream image substring -> fork image substring
declare -A IMAGE_MAP=(
    [rancher/net]=ghcr.io/mtpark-ai/rancher-classic/net
    [rancher/healthcheck]=ghcr.io/mtpark-ai/rancher-classic/healthcheck
    [rancher/scheduler]=ghcr.io/mtpark-ai/rancher-classic/scheduler
    [rancher/metadata]=ghcr.io/mtpark-ai/rancher-classic/metadata
    [rancher/dns]=ghcr.io/mtpark-ai/rancher-classic/dns
    [rancher/lb-service-haproxy]=ghcr.io/mtpark-ai/rancher-classic/lb
    [rancher/network-manager]=ghcr.io/mtpark-ai/rancher-classic/net
    [rancher/per-host-subnet]=ghcr.io/mtpark-ai/rancher-classic/net
    [rancher/secrets]=ghcr.io/mtpark-ai/rancher-classic/secrets
    [rancher/container-crontab]=ghcr.io/mtpark-ai/rancher-classic/container-crontab
)

seed_one() {
    local tpl_dir="$1"
    local name
    name=$(basename "$tpl_dir")

    ## find latest numeric version dir
    local latest
    latest=$(ls -1d "$tpl_dir"/[0-9]* 2>/dev/null | sed 's|.*/||' | sort -n | tail -1)
    [ -z "$latest" ] && { echo "skip   $name (no version subdirs)"; return; }

    local new=$((latest + 1))
    local src="$tpl_dir/$latest"
    local dst="$tpl_dir/$new"

    if [ -d "$dst" ]; then
        echo "skip   $name (already has v$new)"
        return
    fi

    echo "seed   $name: $latest -> $new"
    cp -r "$src" "$dst"

    ## Rewrite all image refs.
    for f in "$dst"/docker-compose.yml.tpl "$dst"/docker-compose.yml "$dst"/rancher-compose.yml; do
        [ -f "$f" ] || continue
        for k in "${!IMAGE_MAP[@]}"; do
            local v="${IMAGE_MAP[$k]}"
            ## image: rancher/net:v0.11.9 -> image: ghcr.io/mtpark-ai/rancher-classic/net:1.7.0
            sed -i -E "s|image:[[:space:]]*${k}:[^[:space:]]*|image: ${v}:1.7.0|g" "$f"
            ## image: rancher/net:holder -> image: ghcr.io/mtpark-ai/rancher-classic/net:1.7.0
            sed -i -E "s|image:[[:space:]]*${k//\//\\/}:holder|image: ${v}:1.7.0|g" "$f" 2>/dev/null || true
        done
    done

    ## Bump minimum_rancher_version + version + add upgrade_from.
    local rc="$dst/rancher-compose.yml"
    if [ -f "$rc" ]; then
        sed -i -E 's|minimum_rancher_version:.*|minimum_rancher_version: v1.7.0|' "$rc"
        sed -i -E 's|version:[[:space:]]*"?v?[0-9]+\.[0-9]+\.[0-9]+[A-Za-z0-9\.\-]*"?|version: "v1.7.0"|' "$rc"
        ## insert upgrade_from if it doesn't exist
        if ! grep -q '^[[:space:]]*upgrade_from:' "$rc"; then
            sed -i '/^[[:space:]]*minimum_rancher_version:/a\  upgrade_from: ">v0.0.0"' "$rc"
        fi
    fi
}

for d in "$CATALOG"/*/; do
    seed_one "${d%/}"
done

echo
echo "done. Inspect with: git diff components/catalog/infra-templates/"
